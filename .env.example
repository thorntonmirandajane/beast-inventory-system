# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/beast_inventory?schema=public"

# JWT Secret (change this in production!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Node environment
NODE_ENV="development"

# Shopify (Bowmar/archery store — read-only, reused from archery-brand-brain)
ARCHERY_SHOPIFY_STORE="your-archery-store.myshopify.com"
ARCHERY_SHOPIFY_TOKEN="shpat_xxxx"
# Optional: pin the Gallatin location id (gid://shopify/Location/...). If unset,
# the client looks up an active location whose name contains "Gallatin".
GALLATIN_LOCATION_ID=""

# Beast Broadhead Shopify store (read-only). Optional — if unset, the forecasting
# Unfulfilled tab shows only Archery orders. Same creds the archery Brand Brain
# uses. When set, unfulfilled line items are pulled from BOTH stores and split
# into Beast / Archery / Total columns.
BEAST_SHOPIFY_STORE="your-beast-store.myshopify.com"
BEAST_SHOPIFY_TOKEN="shpat_xxxx"

# ShipHero (Bowmar Archery LLC — read-only, source of truth for on-hand inventory).
# Used by the forecasting page to populate "Current in Gallatin" with the real
# physical on-hand count at the Apex warehouse instead of Shopify's `available`.
# Username/password = your ShipHero login. The REST API shuts down Sept 1; this
# uses the GraphQL API (https://public-api.shiphero.com/graphql).
SHIPHERO_USERNAME="you@bowmarshop.com"
SHIPHERO_PASSWORD="your-shiphero-password"
# Optional: skip username/password and use a long-lived refresh token instead.
SHIPHERO_REFRESH_TOKEN=""
# Warehouse to read on-hand from. Matched against the ShipHero warehouse
# identifier / address name (default "Apex"). Or pin the exact id to skip lookup.
SHIPHERO_WAREHOUSE="Apex"
SHIPHERO_WAREHOUSE_ID=""
# Optional: only needed if logging in as a 3PL parent account and you must scope
# to the Bowmar Archery LLC customer account explicitly.
SHIPHERO_CUSTOMER_ACCOUNT_ID=""

# Queued-orders integration (read-only feed of programmed/scheduled orders)
QUEUED_ORDERS_API_URL="https://queued-orders.yourdomain.com"
# Shared bearer-style secret — set the SAME value in queued-orders' env as
# BEAST_API_SECRET. Sent by beast in the x-beast-secret header.
BEAST_API_SECRET="generate-a-long-random-string"
