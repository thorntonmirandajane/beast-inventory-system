# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/beast_inventory?schema=public"

# JWT Secret (change this in production!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Node environment
NODE_ENV="development"

# Shopify (Bowmar/archery store — read-only, reused from archery-brand-brain)
ARCHERY_SHOPIFY_STORE="your-archery-store.myshopify.com"
ARCHERY_SHOPIFY_TOKEN="shpat_xxxx"
# Optional: pin the Gallatin location id (gid://shopify/Location/...). If unset,
# the client looks up an active location whose name contains "Gallatin".
GALLATIN_LOCATION_ID=""

# Queued-orders integration (read-only feed of programmed/scheduled orders)
QUEUED_ORDERS_API_URL="https://queued-orders.yourdomain.com"
# Shared bearer-style secret — set the SAME value in queued-orders' env as
# BEAST_API_SECRET. Sent by beast in the x-beast-secret header.
BEAST_API_SECRET="generate-a-long-random-string"
